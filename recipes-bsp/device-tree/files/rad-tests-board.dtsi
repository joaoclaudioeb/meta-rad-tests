&spi1 {
    spi1_dev0: spidev@0 {
        compatible = "rohm,dh2228fv";
        reg = <0>;
        spi-max-frequency = <1000000>;
        status = "okay";
    };

    spi1_dev1: spidev@1 {
        compatible = "rohm,dh2228fv";
        reg = <1>;
        spi-max-frequency = <1000000>;
        status = "okay";
    };

    spi1_dev2: spidev@2 {
        compatible = "rohm,dh2228fv";
        reg = <2>;
        spi-max-frequency = <1000000>;
        status = "okay";
    };
};

&spi0 {
    spi0_dev0: spidev@0 {
        compatible = "rohm,dh2228fv";
        reg = <0>;
        spi-max-frequency = <1000000>;
        status = "okay";
    };

    spi0_dev1: spidev@1 {
        compatible = "rohm,dh2228fv";
        reg = <1>;
        spi-max-frequency = <1000000>;
        status = "okay";
    };

    spi0_dev2: spidev@2 {
        compatible = "rohm,dh2228fv";
        reg = <2>;
        spi-max-frequency = <1000000>;
        status = "okay";
    };
};
