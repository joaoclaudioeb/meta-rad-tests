&spi1 {
    dev0: spidev@0 {
        compatible = "rohm,dh2228fv";
        reg = <0>;
        spi-max-frequency = <1000000>;
        status = "okay";
    };

    dev1: spidev@1 {
        compatible = "rohm,dh2228fv";
        reg = <1>;
        spi-max-frequency = <1000000>;
        status = "okay";
    };

    dev2: spidev@2 {
        compatible = "rohm,dh2228fv";
        reg = <2>;
        spi-max-frequency = <1000000>;
        status = "okay";
    };
};

&spi0 {
    dev0: spidev@0 {
        compatible = "rohm,dh2228fv";
        reg = <0>;
        spi-max-frequency = <1000000>;
        status = "okay";
    };

    dev1: spidev@1 {
        compatible = "rohm,dh2228fv";
        reg = <1>;
        spi-max-frequency = <1000000>;
        status = "okay";
    };

    dev2: spidev@2 {
        compatible = "rohm,dh2228fv";
        reg = <2>;
        spi-max-frequency = <1000000>;
        status = "okay";
    };
};
